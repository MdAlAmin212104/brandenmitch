{%- liquid
        if section.id contains 'menu-drawer' or section.id contains 'main-sidebar'
                if settings.typography_preset == 'classic' or settings.typography_preset == 'brutalist' or settings.typography_preset == 'duet'
                        assign weight = settings.accent_icon_weight
                        if settings.swap_fonts
                                assign weight = settings.base_icon_weight
                        endif
                else 
                        assign weight =  settings.base_icon_weight
                        if settings.swap_fonts
                                assign weight = settings.accent_icon_weight
                        endif
                endif
        elsif section.id contains 'header' and type != 'secondary_menu' and type != 'main_menu'
                if settings.typography_preset == 'classic' or settings.typography_preset == 'contrast' or settings.typography_preset == 'duet'
                        assign weight = settings.accent_icon_weight
                        if settings.swap_fonts
                                assign weight = settings.base_icon_weight
                        endif
                else 
                        assign weight =  settings.base_icon_weight
                        if settings.swap_fonts
                                assign weight = settings.accent_icon_weight
                        endif
                endif
        elsif section.id contains 'secondary-header' and type != 'secondary_menu' and type != 'main_menu'
                if settings.typography_preset == 'classic' or settings.typography_preset == 'contrast' or settings.typography_preset == 'duet'
                        assign weight = settings.accent_icon_weight
                        if settings.swap_fonts
                                assign weight = settings.base_icon_weight
                        endif
                else 
                        assign weight =  settings.base_icon_weight
                        if settings.swap_fonts
                                assign weight = settings.accent_icon_weight
                        endif
                endif
        else 
                if settings.typography_preset == 'avant_garde'
                        assign weight = settings.accent_icon_weight
                        if settings.swap_fonts
                                assign weight = settings.base_icon_weight
                        endif
                else 
                        assign weight =  settings.base_icon_weight
                        if settings.swap_fonts
                                assign weight = settings.accent_icon_weight
                        endif
                endif
        endif
        assign uppercase_font = false
        assign bolder_font = false
        if settings.typography_preset == 'custom'
                assign weight = settings.custom_icon_weight
                if menu_settings.link_size == 'default' or menu_settings.menu_font_size == 'default'
                        if settings.navigation_item_size == 'default'
                                if settings.uppercase_body_s
                                        assign uppercase_font = true
                                endif
                                if settings.bolder_font_body_s
                                        assign bolder_font = true
                                endif
                        endif
                endif
                
        endif
        assign main_link_size = ''
        if menu_settings.menu_font_size
                assign main_link_size = menu_settings.menu_font_size
        endif
        if menu_settings.link_size
                assign main_link_size = menu_settings.link_size
        endif
-%}


<div class="menu-container {% if section.id contains 'header' %}menu-container--header{% elsif section.id contains 'footer' %}menu-container--footer{% else %}menu-container--{{ section.id }}{% endif %} menu-container--{{ section.settings.grid_columns }} menu-container--{{ menu_settings.block_width }} menu-container--{{ type }}" data-block-index="{{ for_loop.index0 }}" 
     style="--menu-vertical-alignment: {{ menu_settings.menu_vertical_alignment }}; --menu-horizontal-alignment: {{ menu_settings.menu_horizontal_alignment }}; --item-index: {{ for_loop.index }}" {{ block_item.shopify_attributes }}>
    <menu-dropdown>
        <nav class="menu__navigation {% if menu_settings.menu_vertical_alignment == 'space-between' or menu_settings.menu_horizontal_alignment == 'space-between' %}menu__navigation--stretched{% endif %}">
            <ul class="menu__list menu__list--{{ menu_id }}
                    menu__list--{{ settings.white_space }} 
                    {% if section.id contains 'header' %}menu__list--header{% elsif section.id contains 'footer' %}menu__list--footer{% else %}menu__list--{{ section.id }}{% endif %}
                    menu__list--{{ type }} 
                    {% if mega_drawer %}menu__list--column{% endif %}
                    menu__list--{{ menu_settings.menu_view }}
                    menu__list--{{ menu_settings.menu_horizontal_alignment }}
                    {% if menu_settings.dim_text and type == 'secondary_menu' %}dim{% endif %}"
                role="list">
                
                {%- for link in menu_settings_id.links -%}
                    <li class="menu__item menu__item--{{ settings.typography_preset }} {% if menu_settings.link_size != 'default' %}{{ menu_settings.link_size }}{% else %}{% if settings.navigation_item_size != 'default' %} {{ settings.navigation_item_size }}{% endif %}{% if uppercase_font %} uppercase{% endif %}{% if bolder_font %} bolder-font{% endif %}{% endif %} 
                        {% if type == 'main_menu' and menu_settings.menu_font_size != 'default' and section.id contains 'footer' or section.id contains 'main-sidebar' or section.id contains 'menu-drawer' %}{{ menu_settings.menu_font_size }}{% endif %}{% if type == 'main_menu' and menu_settings.menu_font_size == 'default' and section.id contains 'footer' or section.id contains 'main-sidebar' or section.id contains 'menu-drawer' %}{% if settings.navigation_item_size != 'default' %} {{ settings.navigation_item_size }}{% endif %}{% if uppercase_font %} uppercase{% endif %}{% if bolder_font %} bolder-font{% endif %}{% endif %} {% if section.settings.color_type == 'custom' %}color-custom{% elsif section.settings.color_type == 'invert' %}color-invert{% endif %} {% if menu_settings.use_accent_color and type == 'main_menu' %}color-accent{% endif %}">
                        <div class="{{ menu_settings.dropdown_link }} menu__item-title menu__item-title--first-level  {% if link.url == request.path and settings.underline_active_link == true %}menu__item-title--underline{% endif %}
							{% if menu_settings.menu_style == 'expanded' %}menu__item-title--expanded
							{% elsif menu_settings.menu_style == 'collapsible' or section.id contains 'menu-drawer' %}menu__item-title--collapsible
							{% elsif menu_settings.menu_style == 'slide_out' and section.id contains 'main-sidebar' %}menu__item-title--slide_out
							{% elsif section.id contains 'header' or section.id contains 'secondary-header' %}menu__item-title--header{% endif %}
                                                        {% if menu_settings.menu_style == 'slide_out' and link.links.size > 0 %}menu__item-title--hover{% endif %}
							{% if settings.allow_transparent_navigation and settings.navigation_layout == 'sidebar_based' and section.id contains 'sidebar' and section.settings.color_type == 'default' %}scroll-color{% endif %}">
                                {% liquid 
                                        assign downcased_link_title = link.title | downcase
                                        assign downcased_highlighted_items = menu_settings.highlight_menu_item | downcase | split: ','
                                        assign highlight_item = false
                                        for highlighted_item in downcased_highlighted_items
                                                assign highlighted_item_strip = highlighted_item | strip
                                                if highlighted_item_strip == downcased_link_title
                                                        assign highlight_item = true
                                                endif
                                        endfor
                                %}
                            <a class="menu__item-link hover-link{% if highlight_item %} link--highlighted{% endif %}" href="{{ link.url }}" {% if link.url contains 'http://' or link.url contains 'https://' %}target="_blank"{% endif %}>
                                <div class="menu__item-link-title {% if link.current and settings.underline_active_link == true %}underline-active{% endif %} {% if settings.enable_animated_underline and settings.enable_rolling_hover == false %}link-animation--underline{% elsif settings.enable_rolling_hover %}link-animation--slide{% else %}link-animation{% endif %}">
									<span data-hover="{{ link.title }}">{{ link.title }}</span>
                                </div>
                            </a>
                            {% unless section.id contains 'footer' %}
                                {%- if link.links.size > 0 and type != 'secondary_menu' and menu_settings.menu_style != 'expanded' and  menu_settings.menu_view != 'row' -%}
                                        {% if menu_settings.menu_style == 'slide_out' %}
                                                <div class="dropdown-icon dropdown-icon--chevron dropdown-icon--first-level" tabindex="0"> 		
                                                        {% if weight == 'regular' %}
                                                                {% render 'icon', icon: 'close-chevron-regular' %}
                                                        {% elsif weight == 'medium' %}
                                                                {% render 'icon', icon: 'close-chevron-medium' %}
                                                        {% elsif weight == 'bold' %}
                                                                {% render 'icon', icon: 'close-chevron-bold' %}
                                                        {% endif %}
                                                </div>
                                        {% elsif section.id contains 'menu-drawer' or section.id contains 'header' or section.id contains 'secondary-header' or menu_settings.menu_style == 'collapsible' %}
                                        {%- if settings.dropdown_icon == 'chevron' -%}
                                                <div class="dropdown-icon dropdown-icon--chevron dropdown-icon--first-level" tabindex="0">				
                                                        {% if weight == 'regular' %}
                                                                {% render 'icon', icon: 'close-chevron-regular' %}
                                                        {% elsif weight == 'medium' %}
                                                                {% render 'icon', icon: 'close-chevron-medium' %}
                                                        {% elsif weight == 'bold' %}
                                                                {% render 'icon', icon: 'close-chevron-bold' %}
                                                        {% endif %}					
                                                </div>   
                                        {%- elsif settings.dropdown_icon == 'plus' -%}
                                                <div class="dropdown-icon dropdown-icon--plus dropdown-icon--first-level" tabindex="0">				
                                                        {% if weight == 'regular' %}
                                                                {% render 'icon', icon: 'plus-regular' %}
                                                        {% elsif weight == 'medium' %}
                                                                {% render 'icon', icon: 'plus-medium' %}
                                                        {% elsif weight == 'bold' %}
                                                                {% render 'icon', icon: 'plus-bold' %}
                                                        {% endif %}				
                                                </div>
                                                <div class="dropdown-icon dropdown-icon--minus dropdown-icon--first-level" tabindex="-1">				
                                                        {% if weight == 'regular' %}
                                                                {% render 'icon', icon: 'minus-regular' %}
                                                        {% elsif weight == 'medium' %}
                                                                {% render 'icon', icon: 'minus-medium' %}
                                                        {% elsif weight == 'bold' %}
                                                                {% render 'icon', icon: 'minus-bold' %}
                                                        {% endif %}				
                                                </div>
                                        {%- endif -%}
                                        {% endif %}
                                {% endif %}
                            {% endunless %}
                        </div>
                                {%- liquid
                                        assign enable_mega_menu = false
                                        assign link_title_handle = link.title | handle

                                        for block in blocks
                                                assign menu_title_handle = block.settings.dropdown_link | handle
                                                assign mega_menu_width = block.settings.width
                                                assign mega_menu_title = block.settings.menu_heading
                                                if menu_title_handle == link_title_handle
                                                assign enable_mega_menu = true
                                                assign mega_menu_block = block.settings
                                                assign mega_menu_block_id = block.id
                                                endif
                                        endfor
                                -%}
                                {%- if link.links.size > 0 and type != 'secondary_menu' and section.id != 'footer' or link.links.size > 0 and type != 'secondary_menu' and section.id == 'secondary-header' or link.links.size > 0 and type != 'secondary_menu' and section.id == 'header' or link.links.size > 0 and type != 'secondary_menu' and section.id != 'menu-drawer' -%}
                                        {% liquid
                                                assign nested_menu_font_size = ''
                                                if settings.typography_preset == 'custom'
                                                if menu_settings.nested_menu_size == 'one_level_down'
                                                        if main_link_size == 'heading_m' or main_link_size == 'heading_m_uppercase'
                                                                assign nested_menu_font_size = 'heading_s'
                                                        endif
                                                        if main_link_size == 'heading_s' or main_link_size == 'heading_s_uppercase'
                                                                assign nested_menu_font_size = 'heading_xs'
                                                        endif
                                                        if main_link_size == 'heading_xs' or main_link_size == 'heading_xs_uppercase'
                                                                assign nested_menu_font_size = 'body_l'
                                                        endif
                                                endif
                                                if menu_settings.nested_menu_size == 'one_level_down_uppercase'
                                                        if main_link_size == 'heading_m' or main_link_size == 'heading_m_uppercase'
                                                                assign nested_menu_font_size = 'heading_s_uppercase'
                                                        endif
                                                        if main_link_size == 'heading_s' or main_link_size == 'heading_s_uppercase'
                                                                assign nested_menu_font_size = 'heading_xs_uppercase'
                                                        endif
                                                        if main_link_size == 'heading_xs' or main_link_size == 'heading_xs_uppercase'
                                                                assign nested_menu_font_size = 'body_l_uppercase'
                                                        endif
                                                endif
                                                if menu_settings.nested_menu_size == 'two_levels_down'
                                                        if main_link_size == 'heading_m' or main_link_size == 'heading_m_uppercase'
                                                                assign nested_menu_font_size = 'heading_xs'
                                                        endif
                                                        if main_link_size == 'heading_s' or main_link_size == 'heading_s_uppercase'
                                                                assign nested_menu_font_size = 'body_l'
                                                        endif
                                                        if main_link_size == 'heading_xs' or main_link_size == 'heading_xs_uppercase'
                                                                assign nested_menu_font_size = 'body_m'
                                                        endif
                                                endif
                                                if menu_settings.nested_menu_size == 'two_levels_down'
                                                        if main_link_size == 'heading_m' or main_link_size == 'heading_m_uppercase'
                                                                assign nested_menu_font_size = 'heading_xs_uppercase'
                                                        endif
                                                        if main_link_size == 'heading_s' or main_link_size == 'heading_s_uppercase'
                                                                assign nested_menu_font_size = 'body_l_uppercase'
                                                        endif
                                                        if main_link_size == 'heading_xs' or main_link_size == 'heading_xs_uppercase'
                                                                assign nested_menu_font_size = 'body_m_uppercase'
                                                        endif
                                                endif
                                                endif
                                        %}
                                        <div class="menu__dropdown-container {% if enable_mega_menu and section.id == 'header' or enable_mega_menu and section.id == 'secondary-header' %}mega-menu mega-menu--{{ mega_menu_block.width }}{% endif %} menu__dropdown-container--{{ settings.white_space }} {% if section.settings.color_type == 'custom' %}color-custom{% elsif section.settings.color_type == 'invert' %}color-invert{% endif %} {% if menu_settings.use_accent_color and type == 'main_menu' %}color-accent{% endif %} {% unless menu_settings.nested_menu_size == 'disable' %}menu__dropdown-container--{{ menu_settings.nested_menu_size }}{% endunless %}{% if settings.typography_preset == 'custom' and menu_settings.nested_menu_size != 'disable' %}{{ nested_menu_font_size }}{% endif %}">
                                                        {% style %}
                                                                .menu__list--header .menu__dropdown-container {
                                                                        --layout-text-color: 
                                                                        {{ settings.layout_text_color.red }},
                                                                        {{ settings.layout_text_color.green }}, 
                                                                        {{ settings.layout_text_color.blue }};
                                                                }
                                                        {% endstyle %}
                                                        {%- if enable_mega_menu and section.id == 'header' or enable_mega_menu and section.id == 'secondary-header' -%}
                                                                {% render 'mega-menu', link: link, block: mega_menu_block, id: mega_menu_block_id, mega_block: block, menu_id: mega_menu_block_id %}
                                                                {{ 'mega-menu.css' | asset_url | stylesheet_tag }}
                                                        {%- endif -%}
                                                        {% if section.id contains 'main-sidebar' and menu_settings.menu_style == 'slide_out' %}<div class="menu__dropdown-container--wrapper"><div class="slide-out-container">{% endif %}
                                                                <ul class="menu__dropdown-child">
                                                                        {% for child_link in link.links %}
                                                                                <li class="menu__dropdown-child-item">
                                                                                        <div class="menu__item-title menu__item-title--second-level {% if nested_menu_font_size != '' %}{{ nested_menu_font_size }}{% endif %}
                                                                                                {% if settings.allow_transparent_navigation and settings.navigation_layout == 'sidebar_based' and section.id contains 'sidebar' and section.settings.color_type == 'default' and menu_settings.menu_style != 'slide_out' %}scroll-color{% endif %}">
                                                                                                {% liquid 
                                                                                                        assign downcased_link_title = child_link.title | downcase
                                                                                                        assign downcased_highlighted_items = menu_settings.highlight_menu_item | downcase | split: ','
                                                                                                        assign highlight_item = false
                                                                                                        for highlighted_item in downcased_highlighted_items
                                                                                                            assign highlighted_item_strip = highlighted_item | strip
                                                                                                            if highlighted_item_strip == downcased_link_title
                                                                                                                assign highlight_item = true
                                                                                                            endif
                                                                                                        endfor
                                                                                                %}
                                                                                                <a class="menu__dropdown-child-item-link hover-link{% if highlight_item %} link--highlighted{% endif %}" href="{{ child_link.url }}" {% if child_link.url contains 'http://' or child_link.url contains 'https://' %}target="_blank"{% endif %} {% if menu_settings.menu_style == 'expanded' %}tabindex="0"{% else %}tabindex="-1"{% endif %}>
                                                                                                        <div class="menu__item-link-title {% if settings.enable_animated_underline and settings.enable_rolling_hover == false %}link-animation--underline{% elsif settings.enable_rolling_hover %}link-animation--slide{% else %}link-animation{% endif %} {% if child_link.current and settings.underline_active_link == true %}underline-active{% endif %} {% if settings.enable_animated_underline and settings.enable_rolling_hover == false %}link-animation--underline{% elsif settings.enable_rolling_hover %}link-animation--slide{% else %}link-animation{% endif %}">
                                                                                                                <span data-hover="{{ child_link.title }}">{{ child_link.title }}</span>
                                                                                                        </div>
                                                                                                </a>
                                                                                                {% if child_link.links.size > 0 %}
                                                                                                        {%- if settings.dropdown_icon == 'chevron' -%}
                                                                                                        <div class="dropdown-icon dropdown-icon--chevron dropdown-icon--second-level" tabindex="0">
                                                                                                                        {% if weight == 'regular' %}
                                                                                                                                        {% render 'icon', icon: 'close-chevron-regular' %}
                                                                                                                        {% elsif weight == 'medium' %}
                                                                                                                                        {% render 'icon', icon: 'close-chevron-medium' %}
                                                                                                                        {% elsif weight == 'bold' %}
                                                                                                                                        {% render 'icon', icon: 'close-chevron-bold' %}
                                                                                                                        {% endif %}
                                                                                                        </div>
                                                                                                        {%- elsif settings.dropdown_icon == 'plus' -%}
                                                                                                        <div class="dropdown-icon dropdown-icon--plus dropdown-icon--second-level" tabindex="0">
                                                                                                                        {% if weight == 'regular' %}
                                                                                                                                        {% render 'icon', icon: 'plus-regular' %}
                                                                                                                        {% elsif weight == 'medium' %}
                                                                                                                                        {% render 'icon', icon: 'plus-medium' %}
                                                                                                                        {% elsif weight == 'bold' %}
                                                                                                                                        {% render 'icon', icon: 'plus-bold' %}
                                                                                                                        {% endif %}
                                                                                                        </div>
                                                                                                        <div class="dropdown-icon dropdown-icon--minus dropdown-icon--second-level" tabindex="-1">
                                                                                                                        {% if weight == 'regular' %}
                                                                                                                                        {% render 'icon', icon: 'minus-regular' %}
                                                                                                                        {% elsif weight == 'medium' %}
                                                                                                                                        {% render 'icon', icon: 'minus-medium' %}
                                                                                                                        {% elsif weight == 'bold' %}
                                                                                                                                        {% render 'icon', icon: 'minus-bold' %}
                                                                                                                        {% endif %}
                                                                                                        </div>
                                                                                                        {%- endif -%}
                                                                                                {% endif %}
                                                                                        </div>
                                                                                        {% if child_link.links.size > 0 %}
                                                                                                <div class="menu__dropdown-grandchild-container">
                                                                                                        <ul class="menu__dropdown-grandchild">
                                                                                                        {% for grandchild_link in child_link.links %}
                                                                                                                <li class="menu__dropdown-grandchild-item {% if settings.allow_transparent_navigation and settings.navigation_layout == 'sidebar_based' and section.id contains 'sidebar' and section.settings.color_type == 'default' and menu_settings.menu_style != 'slide_out' %}scroll-color{% endif %}{% if nested_menu_font_size != '' %} {{ nested_menu_font_size }}{% endif %}">
                                                                                                                {% liquid 
                                                                                                                        assign downcased_link_title = grandchild_link.title | downcase
                                                                                                                        assign downcased_highlighted_items = menu_settings.highlight_menu_item | downcase | split: ','
                                                                                                                        assign highlight_item = false
                                                                                                                        for highlighted_item in downcased_highlighted_items
                                                                                                                                assign highlighted_item_strip = highlighted_item | strip
                                                                                                                                if highlighted_item_strip == downcased_link_title
                                                                                                                                        assign highlight_item = true
                                                                                                                                endif
                                                                                                                        endfor
                                                                                                                %}
                                                                                                                <a class="menu__dropdown-grandchild-link hover-link{% if highlight_item %} link--highlighted{% endif %}" href="{{ grandchild_link.url }}" {% if grandchild_link.url contains 'http://' or grandchild_link.url contains 'https://' %}target="_blank"{% endif %} tabindex="-1">
                                                                                                                        <div class="menu__item-link-title {% if settings.enable_animated_underline and settings.enable_rolling_hover == false %}link-animation--underline{% elsif grandchild_link.current and settings.underline_active_link == true %}underline-active{% endif %} {% if settings.enable_animated_underline and settings.enable_rolling_hover == false %}link-animation--underline{% elsif settings.enable_rolling_hover %}link-animation--slide{% else %}link-animation{% endif %}">
                                                                                                                                <span data-hover="{{ grandchild_link.title }}">{{ grandchild_link.title }}</span>
                                                                                                                        </div>
                                                                                                                </a>
                                                                                                                </li>
                                                                                                        {% endfor %}
                                                                                                        </ul>
                                                                                                </div>
                                                                                        {% endif %}
                                                                                </li>
                                                                        {% endfor %}
                                                                </ul>
                                                        {% if section.id contains 'main-sidebar' and menu_settings.menu_style == 'slide_out' %}</div></div>{% endif %}
                                                </div>
                                {% if menu_settings.menu_style == 'slide_out' and section.id contains 'main-sidebar' %}
                                        <div class="menu-divider"></div>
                                {% endif %}
                                {% endif %}
                    </li>
                {%- endfor -%}
            </ul>
        </nav>
    </menu-dropdown>
</div>