                                  {%- when 'custom_options_m_line' -%}
                                      {%- render 'custom-options-multi-line', block: block, weight_accordion_title: weight_accordion_title -%}
                                  {%- when 'custom_options_upload' -%}
                                      {%- render 'custom-options-upload', block: block, weight_accordion_title: weight_accordion_title -%}
                                  {%- when 'custom_options_date' -%}
