<div role="dialog" aria-modal="true" class="quick-view__content hide-cover" tabindex="-1">
{{ 'section-main-product.css' | asset_url | stylesheet_tag }}
{{ 'component-accordion.css' | asset_url | stylesheet_tag }}
{{ 'component-price.css' | asset_url | stylesheet_tag }}
{{ 'component-slider.css' | asset_url | stylesheet_tag }}
{{ 'component-rating.css' | asset_url | stylesheet_tag }}
{{ 'component-loading.css' | asset_url | stylesheet_tag }}
{{ 'component-deffered-media.css' | asset_url | stylesheet_tag }}
{{ 'component-share.css' | asset_url | stylesheet_tag }}
{{ 'component-product-related-collections.css' | asset_url | stylesheet_tag }}
{{ 'component-product-features.css' | asset_url | stylesheet_tag }}
{{ 'component-product-card.css' | asset_url | stylesheet_tag }}
{{ 'component-model-viewer-ui.css' | asset_url | stylesheet_tag }}
{{ 'component-rte.css' | asset_url | stylesheet_tag }}

{% style %}
#shopify-section-{{ section.id }} {
  --focal-point: {{ section.settings.focal_point }};
  {% if section.settings.context_image_radius == 'default' %}
    --context-image-radius: {{ settings.images_and_sections_radius }};
  {% else %}
    --context-image-radius: {{ section.settings.context_image_radius }};
  {% endif %}
}
.share--icon  {
  height: {{ 24 | times: settings.desktop_font_scale | divided_by: 100.0 | round | at_least: 24 }}px;
}
.heading_s .share--icon,
.heading_s_uppercase .share--icon {
  height: {{ 46 | times: settings.desktop_font_scale | divided_by: 100.0 | round | at_least: 16 | at_most: 128 }}px;
}
.heading_xs .share--icon,
.heading_xs_uppercase .share--icon {
  height: {{ 36 | times: settings.desktop_font_scale | divided_by: 100.0 | round | at_least: 16 | at_most: 128 }}px;
}
.body_l .share--icon,
.body_l_uppercase .share--icon {
    height: {{ 28 | times: settings.desktop_font_scale | divided_by: 100.0 | round | at_least: 16 }}px;
}
.body_m .share--icon,
.body_m_uppercase .share--icon {
    height: {{ 26 | times: settings.desktop_font_scale | divided_by: 100.0 | round | at_least: 16 }}px;
}
.label_font .share--icon,
.label_font_uppercase .share--icon {
    height: {{ 16 | times: settings.desktop_font_scale | divided_by: 100.0 | round | at_least: 16 }}px;
}
.custom-type-preset .share--icon {
  height: max(24px, calc(var(--body-s-font-size) * var(--body-s-line-height)));
}
.custom-type-preset .heading_s .share--icon,
.custom-type-preset .heading_s_uppercase .share--icon {
  height: max(16px, calc(var(--heading-s-font-size) * var(--heading-s-line-height)));	
}
.custom-type-preset .heading_xs .share--icon,
.custom-type-preset .heading_xs_uppercase .share--icon {
  height: max(16px, calc(var(--heading-xs-font-size) * var(--heading-xs-line-height)));	
}
.custom-type-preset .body_l .share--icon,
.custom-type-preset .body_l_uppercase .share--icon {
    height: max(16px, calc(var(--body-l-font-size) * var(--body-l-line-height)));
}
.custom-type-preset .body_m .share--icon,
.custom-type-preset .body_m_uppercase .share--icon {
    height: max(16px, calc(var(--body-m-font-size) * var(--body-m-line-height)));
}
.custom-type-preset .label_font .share--icon,
.custom-type-preset .label_font_uppercase .share--icon {
    height: max(16px, calc(var(--label-font-size) * var(--label-line-height)));
}

@media screen and (max-width: 920px) {
  .share--icon {
    height: {{ 24 | times: settings.mobile_font_scale | divided_by: 100.0 | round | at_least: 24 }}px;
  }
  .heading_s .share--icon,
  .heading_s_uppercase .share--icon {
    height: {{ 46 | times: settings.mobile_font_scale | divided_by: 100.0 | round | at_least: 16 | at_most: 128 }}px;
  }
  .heading_xs .share--icon,
  .heading_xs_uppercase .share--icon {
    height: {{ 36 | times: settings.mobile_font_scale | divided_by: 100.0 | round | at_least: 16 | at_most: 128 }}px;
  }
  .body_l .share--icon,
  .body_l_uppercase .share--icon {
      height: {{ 28 | times: settings.mobile_font_scale | divided_by: 100.0 | round | at_least: 16 }}px;
  }
  .body_m .share--icon,
  .body_m_uppercase .share--icon {
      height: {{ 26 | times: settings.mobile_font_scale | divided_by: 100.0 | round | at_least: 16 }}px;
  }
  .label_font .share--icon,
  .label_font_uppercase .share--icon {
      height: {{ 16 | times: settings.mobile_font_scale | divided_by: 100.0 | round | at_least: 16 }}px;
  }
}
{% endstyle %}

{%- liquid 
  if settings.typography_preset == 'avant_garde'
    assign weight = settings.accent_icon_weight
    if settings.swap_fonts
      assign weight = settings.base_icon_weight
    endif
else 
    assign weight =  settings.base_icon_weight
    if settings.swap_fonts
      assign weight = settings.accent_icon_weight
    endif
endif

assign settings_page_width = settings.max_page_width | append: 'px'
    if settings.max_page_width == 'full_width'
    assign settings_page_width = '100vw'
    endif

if settings.typography_preset == 'avant_garde' or settings.typography_preset == 'duet'
			assign weight_accordion_title = settings.accent_icon_weight
			if settings.swap_fonts
					assign weight_accordion_title = settings.base_icon_weight
			endif
    else 
      assign weight_accordion_title =  settings.base_icon_weight
      if settings.swap_fonts
          assign weight_accordion_title = settings.accent_icon_weight
      endif
    endif
    if settings.typography_preset == 'custom'
    assign weight = settings.custom_icon_weight
    assign weight_accordion_title = settings.custom_icon_weight
   endif

  assign product_form_id = 'product-form-' | append: section.id
-%}

<link rel="stylesheet" href="{{ 'component-deffered-media.css' | asset_url }}" media="print" onload="this.media='all'">
<link rel="stylesheet" href="{{ 'component-product-reviews.css' | asset_url }}" media="print" onload="this.media='all'">

<script src="{{ 'product-form.js' | asset_url }}" defer="defer"></script>
{%- assign first_3d_model = product.media | where: "media_type", "model" | first -%}
{%- if first_3d_model -%}
  {{ 'component-product-model.css' | asset_url | stylesheet_tag }}
  <link id="ModelViewerStyle" rel="stylesheet" href="https://cdn.shopify.com/shopifycloud/model-viewer-ui/assets/v1.0/model-viewer-ui.css" media="print" onload="this.media='all'">
  <link id="ModelViewerOverride" rel="stylesheet" href="{{ 'component-model-viewer-ui.css' | asset_url }}" media="print" onload="this.media='all'">
{%- endif -%}
{% if template.suffix != 'quick-view' %}<modal-dialog>{% endif %}
{% if section.id contains 'quick-view' %}<div class="overlay open"></div>{% endif %}
<div class="popup-wrapper open popup-wrapper__quick-view main-product">
    {% style %}
        #shopify-section-{{ section.id }} .popup-wrapper,
        #shopify-section-{{ section.id }} .open.overlay__quick-view {
            --layout-text-color:
                {{ settings.layout_text_color.red }},
                {{ settings.layout_text_color.green }}, 
                {{ settings.layout_text_color.blue }};
            --layout-background-color:
                {{ settings.layout_background_color.red }},
                {{ settings.layout_background_color.green }},
                {{ settings.layout_background_color.blue }};
            --rating-color: 
                {{ settings.rating_color.red }},
                {{ settings.rating_color.green }},
                {{ settings.rating_color.blue }};
        }
        .overlay-quick-view {
          display: none;
        }
        .quick-view-section .overlay-quick-view {
          display: block;
          position: fixed;
          width: 100vw;
          height: 100vh;
          background-color: rgb(var(--layout-background-color));
          z-index: 10;
          top: 0;
        }
    {% endstyle %}
    <div class="scroll-area hide-scrollbar">
      <div class="button-wrapper {% if settings.enable_buttons_zoom %}buttons-zoom{% endif %}">
          <button type="button" class="button-close close-popup">
              {% if weight == 'regular' %}
                  {% render 'icon', icon: 'cross-regular' %}
              {% elsif weight == 'medium' %}
                  {% render 'icon', icon: 'cross-medium' %}
              {% elsif weight == 'bold' %}
                  {% render 'icon', icon: 'cross-bold' %}
              {% endif %}
          </button>
      </div>
      <div class="popup-content">
              <section class="section" data-section="{{ section.id }}">
                  {%- liquid 
                      if section.settings.focal_point == '20% 0'
                      assign vertical_aligment = 'vertical_top'
                      assign horizontal_aligment = 'horizontal_left'
                      elsif section.settings.focal_point == 'top center'
                      assign vertical_aligment = 'vertical_top'
                      assign horizontal_aligment = 'horizontal_center'
                      elsif section.settings.focal_point == '80% 0'
                      assign vertical_aligment = 'vertical_top'
                      assign horizontal_aligment = 'horizontal_right'
                      elsif section.settings.focal_point == '20% 50%'
                      assign vertical_aligment = 'vertical_center'
                      assign horizontal_aligment = 'horizontal_left'
                      elsif section.settings.focal_point == 'center center'
                      assign vertical_aligment = 'vertical_center'
                      assign horizontal_aligment = 'horizontal_center'
                      elsif section.settings.focal_point == '80% 50%'
                      assign vertical_aligment = 'vertical_center'
                      assign horizontal_aligment = 'horizontal_right'
                      elsif section.settings.focal_point == '20% 100%'
                      assign vertical_aligment = 'vertical_bottom'
                      assign horizontal_aligment = 'horizontal_left'
                      elsif section.settings.focal_point == 'bottom center'
                      assign vertical_aligment = 'vertical_bottom'
                      assign horizontal_aligment = 'horizontal_center'
                      elsif section.settings.focal_point == '80% 100%'
                      assign vertical_aligment = 'vertical_bottom'
                      assign horizontal_aligment = 'horizontal_right'
                      endif
                  -%}
                      <div class="product  product--medium product--{{ section.settings.desktop_gallery_style }} product--{{ settings.white_space }} {% if settings.show_lines %}product--lines{% endif %} {% if section.settings.swap_position %}product--reverse{% endif %}">
                      <product-recently-viewed data-product-id="{{ product.id }}" class="hidden-block"></product-recently-viewed>
                      <div class="grid__item product__media-wrapper">
                          <media-gallery id="MediaGallery-{{ section.id }}" role="region" {% if section.settings.sticky_content %} class="container--sticky"{% endif %} aria-label="{{ 'products.product.media.gallery_viewer' | t }}" data-desktop-layout="{{ section.settings.desktop_gallery_style }}">
                          <div id="GalleryStatus-{{ section.id }}" class="visually-hidden" role="status"></div>
                          <div class="slider-block slider-container-js {% if section.settings.desktop_gallery_style == 'thumbnails_left' %}slider-block--row{% else %}slider-block--column{% endif %}">
                              <slider-component id="GalleryViewer-{{ section.id }}" class="slider-mobile-gutter slider-mobile-gutter--large">
                              <a class="skip-to-content-link button visually-hidden quick-add-hidden" href="#ProductInfo-{{ section.id }}">
                                  {{ "accessibility.skip_to_product_info" | t }}
                              </a>
                              <div class="slider__viewport">

                                  <ul id="Slider-Gallery-{{ section.id }}" class="slider__grid product__media-list {{ section.settings.desktop_gallery_style }} {% if product.media.size == 1 %}one_column{% endif %} contains-media {% if section.settings.desktop_gallery_style == 'one_column_grid' or section.settings.desktop_gallery_style == 'two_columns_grid' %}grid grid--peek{% else %}{% if section.settings.image_ratio != 'original' %}ratio-{{ section.settings.image_ratio }}{% endif %}{% endif %} list-unstyled product-slider slider--mobile slider-main--{{ section.settings.image_ratio }} {{ vertical_aligment }} {{ horizontal_aligment }}{% if section.settings.show_media_attached_to_variant %} variant-images{% endif %}{% if section.settings.organize_images or section.settings.first_image_instead_of_variant %} organize_images{% endif %}" role="list" data-count="1" data-count-mobile="1">
                                  {%- liquid
                                      assign variant_images = product.images | where: 'attached_to_variant?', true | map: 'src'
                                      assign variant_alt = product.selected_or_first_available_variant.image.alt | downcase
                                      assign media_count = product.media.size
                                      if section.settings.show_media_attached_to_variant and variant_images.size > 0
                                        assign media_count = variant_images.size
                                      endif
                                      assign media_width = 0.55
                                  -%}
                                  {%- if product.media.size < 1 and settings.product_placeholder != blank -%}
                                      <li tabindex="0" class="product__placeholder lazy-image-container product__media-item--{{ section.settings.image_ratio }} ratio-{{ section.settings.image_ratio }}">
                                      {% if settings.images_loading != 'disable' %}
                                        <figure class="lazy-image lazy-image--{{ settings.images_loading }}" style="--desktop-asp-rat: {{ settings.product_placeholder.aspect_ratio }}">
                                      {% endif %}
                                      <img
                                          srcset="{% if settings.product_placeholder.width >= 493 %}{{ settings.product_placeholder | image_url: width: 493 }} 493w,{% endif %}
                                          {% if settings.product_placeholder.width >= 600 %}{{ settings.product_placeholder | image_url: width: 600 }} 600w,{% endif %}
                                          {% if settings.product_placeholder.width >= 713 %}{{ settings.product_placeholder | image_url: width: 713 }} 713w,{% endif %}
                                          {% if settings.product_placeholder.width >= 823 %}{{ settings.product_placeholder | image_url: width: 823 }} 823w,{% endif %}
                                          {% if settings.product_placeholder.width >= 990 %}{{ settings.product_placeholder | image_url: width: 990 }} 990w,{% endif %}
                                          {% if settings.product_placeholder.width >= 1100 %}{{ settings.product_placeholder | image_url: width: 1100 }} 1100w,{% endif %}
                                          {% if settings.product_placeholder.width >= 1206 %}{{ settings.product_placeholder | image_url: width: 1206 }} 1206w,{% endif %}
                                          {% if settings.product_placeholder.width >= 1346 %}{{ settings.product_placeholder | image_url: width: 1346 }} 1346w,{% endif %}
                                          {% if settings.product_placeholder.width >= 1426 %}{{ settings.product_placeholder | image_url: width: 1426 }} 1426w,{% endif %}
                                          {% if settings.product_placeholder.width >= 1646 %}{{ settings.product_placeholder | image_url: width: 1646 }} 1646w,{% endif %}
                                          {% if settings.product_placeholder.width >= 1946 %}{{ settings.product_placeholder | image_url: width: 1946 }} 1946w,{% endif %}
                                          {{ settings.product_placeholder | image_url }} {{ settings.product_placeholder.width }}w"
                                          sizes="(min-width: {{ settings_page_width }}) calc(({{ settings_page_width }} - 100px) * {{ media_width }}), (min-width: 990px) calc({{ media_width | times: 100 }}vw - 10rem), (min-width: 750px) calc((100vw - 11.5rem) / 2), calc(100vw - 4rem)"
                                          class="banner__image banner__image--mobile"
                                          src="{{ settings.product_placeholder | image_url: width: 1946 }}"
                                          loading="lazy"
                                          {% if settings.images_loading != 'disable' %}
                                            onload="this.parentNode.classList.add('lazyloaded');"
                                          {% endif %}
                                          draggable="false"
                                          alt="{{ settings.product_placeholder.alt | escape }}"
                                          width="{{ settings.product_placeholder.width }}"
                                          height="{{ settings.product_placeholder.width | divided_by: settings.product_placeholder.aspect_ratio | ceil }}"
                                          {% if settings.disable_right_click %}oncontextmenu="return false"{% endif %}
                                      >
                                    {% if settings.images_loading != 'disable' %}
                                      {% if settings.images_loading != 'fade_scale' %}
                                      <div class="lazy-image__preloader lazy-image__preloader--full lazy-image__preloader-{{ settings.images_loading }}" aria-hidden="true">
                                          <img 
                                          alt="{{ settings.product_placeholder.alt | escape }}" 
                                          src="{{ settings.product_placeholder | image_url: width: 10 }}"
                                          draggable="false"
                                          width="10" 
                                          height="10">
                                      </div>
                                      {% endif %}
                                      </figure>
                                  {% endif %}
                                      </li>
                                  {%- endif -%}
                                  {% liquid 
                                    assign admin_order = false
                                    if section.settings.organize_images
                                      assign admin_order = true
                                    endif
                                    if section.settings.first_image_instead_of_variant
                                      assign admin_order = true
                                    endif
                                  %}
                                  {% if admin_order == false %}
                                    {%- if product.selected_or_first_available_variant.featured_media != nil -%}
                                      {% liquid 
                                        assign featured_media = product.selected_or_first_available_variant.featured_media
                                        if featured_media.alt contains '(' or featured_media.alt contains ')' 
                                          assign featured_media_alt = featured_media.alt | downcase | split: '(' | last | split: ')' | first | prepend: '(' | append: ')'
                                        else
                                          assign featured_media_alt = featured_media.alt | downcase
                                        endif
                                      %}
                                        <li id="Slide-{{ section.id }}-{{ featured_media.id }}" tabindex="0" class="product__media-item product__media-item--{{ section.settings.image_ratio }} lazy-image-container ratio-{{ section.settings.image_ratio }} {% if section.settings.show_media_attached_to_variant and variant_images.size > 0 %}product__media-item--hide{% endif %} snap-align grid__item slider__slide is-active{% if featured_media.media_type != 'image' %} product__media-item--full{% endif %}{% if section.settings.show_media_attached_to_variant and variant_alt contains featured_media_alt  %} product__media-item--variant-alt{% endif %}{% if section.settings.show_media_attached_to_variant and variant_images contains featured_media.src  %} product__media-item--variant{% endif %}" data-media-id="{{ section.id }}-{{ featured_media.id }}" data-product-media-id="{{ featured_media.id }}" data-media-alt="{{ featured_media_alt }}">
                                        {%- assign media_position = 1 -%}
                                        {% render 'product-thumbnail', media: featured_media, position: media_position, loop: section.settings.enable_video_looping, modal_id: section.id, xr_button: true, media_width: media_width, lazy_load: false %}
                                        </li>
                                    {%- endif -%}
                                  {% endif %}
                                  {%- for media in product.media -%}
                                    {% liquid 
                                      if media.alt contains '(' or media.alt contains ')' 
                                        assign media_alt = media.alt | downcase | split: '(' | last | split: ')' | first | prepend: '(' | append: ')' 
                                      else 
                                        assign media_alt = media.alt | downcase
                                      endif
                                      assign admin_order = false
                                      if section.settings.organize_images
                                        assign admin_order = true
                                      endif
                                      if section.settings.first_image_instead_of_variant
                                        assign admin_order = true
                                      endif
                                    %}
                                    {% if admin_order == false %}
                                      {% unless media.id == product.selected_or_first_available_variant.featured_media.id %}
                                        <li id="Slide-{{ section.id }}-{{ media.id }}" tabindex="0" class="{% if media == product.selected_or_first_available_variant.image %}is-active{% endif %} product__media-item product__media-item--{{ section.settings.image_ratio }} lazy-image-container ratio-{{ section.settings.image_ratio }} {% if section.settings.show_media_attached_to_variant and variant_images.size > 0 %}product__media-item--hide{% endif %} snap-align grid__item slider__slide{% if product.selected_or_first_available_variant.featured_media == null and forloop.index == 1 %} is-active{% endif %}{% if media.media_type != 'image' %} product__media-item--full{% endif %}{% if section.settings.show_media_attached_to_variant and variant_alt contains media_alt %} product__media-item--variant-alt{% endif %}{% if section.settings.show_media_attached_to_variant and variant_images contains media.src %} product__media-item--variant{% endif %}{% if product.selected_or_first_available_variant.featured_media == blank %} product__media-item--show{% endif %}" data-media-id="{{ section.id }}-{{ media.id }}" data-product-media-id="{{ media.id }}" data-media-alt="{{ media_alt }}">
                                            {%- liquid
                                            assign media_position = media_position | default: 0 | plus: 1
                                            assign lazy_load = false
                                            if media_position > 1
                                                assign lazy_load = true
                                            endif
                                            render 'product-thumbnail', media: media, position: media_position, loop: section.settings.enable_video_looping, modal_id: section.id, xr_button: true, media_width: media_width, lazy_load: lazy_load
                                            -%}
                                        </li>
                                      {% endunless %}
                                    {% elsif section.settings.organize_images or section.settings.first_image_instead_of_variant %}
                                      <li id="Slide-{{ section.id }}-{{ media.id }}" tabindex="0" class="{% if section.settings.first_image_instead_of_variant and section.settings.show_media_attached_to_variant == false %}{% if forloop.index == 1 %}is-active{% endif %}{% else %}{% if media == product.selected_or_first_available_variant.image %}is-active{% endif %}{% endif %} product__media-item product__media-item--{{ section.settings.image_ratio }} lazy-image-container ratio-{{ section.settings.image_ratio }} {% if section.settings.show_media_attached_to_variant and variant_images.size > 0 %}product__media-item--hide{% endif %} snap-align grid__item slider__slide{% if product.selected_or_first_available_variant.featured_media == null and forloop.index == 1 %} is-active{% endif %}{% if media.media_type != 'image' %} product__media-item--full{% endif %}{% if section.settings.show_media_attached_to_variant and variant_alt contains media_alt %} product__media-item--variant-alt{% endif %}{% if section.settings.show_media_attached_to_variant and variant_images contains media.src %} product__media-item--variant{% endif %}{% if product.selected_or_first_available_variant.featured_media == blank %} product__media-item--show{% endif %}" data-media-id="{{ section.id }}-{{ media.id }}" data-product-media-id="{{ media.id }}" data-media-alt="{{ media_alt }}">
                                        {%- liquid
                                          assign media_position = media_position | default: 0 | plus: 1
                                          assign lazy_load = false
                                          if media_position > 1
                                            assign lazy_load = true
                                          endif
                                          render 'product-thumbnail', media: media, position: media_position, loop: section.settings.enable_video_looping, modal_id: section.id, xr_button: true, media_width: media_width, lazy_load: lazy_load
                                        -%}
                                        {% if section.settings.enable_image_zoom %}
                                          {%- liquid 
                                            if settings.typography_preset == 'avant_garde'
                                                assign weight = settings.accent_icon_weight
                                                if settings.swap_fonts
                                                    assign weight = settings.base_icon_weight
                                                endif
                                            else 
                                                assign weight =  settings.base_icon_weight
                                                if settings.swap_fonts
                                                    assign weight = settings.accent_icon_weight
                                                endif
                                            endif
                                            if settings.typography_preset == 'custom'
                                              assign weight = settings.custom_icon_weight
                                          endif
                                          -%}
                                          {% if media.media_type == 'image' %}
                                            <div class="zoom_icon">
                                                  {% if weight == 'regular' %}
                                                      {% render 'icon-accordion-2', icon: 'zoom-in-regular' %}
                                                  {% elsif weight == 'medium' %}
                                                      {% render 'icon-accordion-2', icon: 'zoom-in-medium' %}
                                                  {% elsif weight == 'bold' %}
                                                      {% render 'icon-accordion-2', icon: 'zoom-in-bold' %}
                                                  {% endif %}
                                            </div>
                                          {% endif %}
                                        {% endif %}
                                      </li>
                                    {% endif %}
                                  {%- endfor -%}
                                  </ul>
                              </div>
                              {% if media_count > 1 %}
                              <div class="slider-buttons quick-add-hidden {% if section.settings.desktop_gallery_style == 'arrows' or section.settings.desktop_gallery_style == 'one_column_grid' or section.settings.desktop_gallery_style == 'two_columns_grid' %}slider-buttons--visible{% endif %}{% if section.settings.mobile_navigation == 'scrollbar' %} buttons-hidden-mobile{% endif %}">
                                  <div class="slider-counter slider-counter--{{ settings.typography_preset }}{% if settings.typography_preset == 'custom' %}{% if settings.uppercase_body_s %} uppercase{% endif %}{% if settings.bolder_font_body_s %} bolder-font{% endif %}{% endif %}">
                                  <span class="slider-counter--current">1</span>
                                  <span class="slider-counter__slash">
                                      {% render 'icon-accordion-2', icon: 'slash' %}
                                  </span>
                                  <span class="visually-hidden">{{ 'general.slider.of' | t }}</span>
                                  <span class="slider-counter--total">{{ media_count }}</span>
                                  </div>
                                  <div class="slider-buttons-items ">
                                      <button type="button" class="slider-button slider-button--prev" name="previous" aria-label="{{ 'general.slider.previous_slide' | t }}">
                                          {% if weight == 'regular' %}
                                                  {% render 'icon-accordion-2', icon: 'arrow-long-left-regular' %}
                                          {% elsif weight == 'medium' %}
                                                  {% render 'icon-accordion-2', icon: 'arrow-long-left-medium' %}
                                          {% elsif weight == 'bold' %}
                                                  {% render 'icon-accordion-2', icon: 'arrow-long-left-bold' %}
                                          {% endif %}
                                      </button>
                                      <button type="button" class="slider-button slider-button--next" name="next" aria-label="{{ 'general.slider.next_slide' | t }}">
                                          {% if weight == 'regular' %}
                                                  {% render 'icon-accordion-2', icon: 'arrow-long-right-regular' %}
                                          {% elsif weight == 'medium' %}
