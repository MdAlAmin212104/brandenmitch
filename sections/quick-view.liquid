                                  <div class="app">{% render block %}</div>
                                  {%- when 'subtitle' -%}
                                      {% if block.settings.subtitle != blank %}
                                      <{{ block.settings.subtitle_tag }} class="product__text product__text--{{ settings.typography_preset }} {% if block.settings.dim_text %}dim{% endif %} {% if block.settings.subtitle_size != 'default' %}{{ block.settings.subtitle_size }}{% endif %}" {{ block.shopify_attributes }}>
                                          {% if block.settings.subtitle == product.vendor %}
                                          {{ product.vendor | link_to_vendor : class: "link" }}
                                          {% else %}
                                          {{- block.settings.subtitle -}}
                                          {% endif %}
                                      </{{ block.settings.subtitle_tag }}>
                                      {% endif %}
                                  {%- when 'title' -%}
                                      <{{ block.settings.heading_tag }} class="product__title {% if settings.accent_color_for_headings %}product__title--accent{% endif %} product__title--{{ settings.typography_preset }} {% if block.settings.title_size != 'default' %}{{ block.settings.title_size }}{% endif %}" {{ block.shopify_attributes }}>
                                      {{ product.title | escape }}
                                      </{{ block.settings.heading_tag }}>
                                  {%- when 'sku' -%}
                                      {% if product.selected_or_first_available_variant.sku != blank %}
                                      <p class="product__sku body-secondary-text--{{ settings.typography_preset }} {% if block.settings.sku_size != 'default' %}{{ block.settings.sku_size }}{% endif %} {% if settings.dim_text %}dim{% endif %}" id="sku-{{ section.id }}" {{ block.shopify_attributes }}>
                                          {{ block.settings.sku_heading }} {{ product.selected_or_first_available_variant.sku }}
                                      </p>
                                      {% endif %}
                                  {%- when 'text' -%}
                                    {% if block.settings.text != blank %}
                                      <div class="product__text product__text--{{ settings.typography_preset }} richtext {% if settings.enable_animated_underline %}richtext-link--underline{% endif %} {% if block.settings.dim_text %}dim{% endif %} {% if block.settings.text_size != 'default' %}{{ block.settings.text_size }}{% endif %}" {{ block.shopify_attributes }}>
                                          {{- block.settings.text -}}
                                      </div>
                                    {% endif %}
                                  {%- when 'description' -%}
                                      <div class="product__description rte rte-block
                                      body-secondary-text--{{ settings.typography_preset }}
                                      {% if block.settings.text_size != 'default' %}{{ block.settings.text_size }}{% endif %}" {{ block.shopify_attributes }}>
                                      {{ product.description }}
                                      </div>
                                  {%- when 'custom_liquid' -%}
                                      <div class="body-secondary-text--{{ settings.typography_preset }}">{{ block.settings.custom_liquid }}</div>
                                  {%- when 'collapsible_tab' -%}
                                      {%- render 'accordion', accordion_settings: block.settings, page: block.settings.page, block_item: block -%}
                                  {%- when 'complementary_products' -%}
                                      {%- render 'complementary-products', complementary_products_settings: block.settings, block_item: block, section_content: false, product: product, url: routes.product_recommendations_url -%}
                                  {%- when 'share' -%}
                                      <div class="share" {{ block.shopify_attributes }}>
                                      {% if block.settings.display_collapsible_link %}
                                          {%- liquid 
                                          if settings.typography_preset == 'avant_garde'
                                              assign weight = settings.accent_icon_weight
                                              if settings.swap_fonts
                                                  assign weight = settings.base_icon_weight
                                              endif
                                          else 
                                              assign weight =  settings.base_icon_weight
                                              if settings.swap_fonts
                                                  assign weight = settings.accent_icon_weight
                                              endif
                                          endif
                                          -%}
                                          <accordion-block>
                                          <div class="accordion-toggle no-js-hidden share-toggle">
                                              <div class="accordion__summary" tabindex="0">
                                              <div class="summary__title share__button hover-opacity share__button--{{ settings.typography_preset }}">
                                                  <div class="summary__title-name">
                                                  <span class="share__title">{{ "products.product.share_button" | t }}</span>
                                                  </div>
                                                  <span class="icon-accordion share__icon">
                                                  <span class="icon-accordion__close share__icon-close">
                                                      {% if weight_accordion_title == 'regular' %}
                                                      {% render 'icon-accordion-2', icon: 'share-regular' %}
                                                      {% elsif weight_accordion_title == 'medium' %}
                                                      {% render 'icon-accordion-2', icon: 'share-medium' %}
                                                      {% elsif weight_accordion_title == 'bold' %}
                                                      {% render 'icon-accordion-2', icon: 'share-bold' %}
                                                      {% endif %}
                                                  </span>
                                                  <span class="icon-accordion__open share__icon-open">
                                                      {% if weight_accordion_title == 'regular' %}
                                                      {% render 'icon', icon: 'cross-regular' %}
                                                      {% elsif weight_accordion_title == 'medium' %}
                                                      {% render 'icon', icon: 'cross-medium' %}
                                                      {% elsif weight_accordion_title == 'bold' %}
                                                      {% render 'icon', icon: 'cross-bold' %}
                                                      {% endif %}
                                                  </span>
                                                  </span>
                                              </div>
                                              </div>
                                              <div class="accordion__panel">
                                              <div class="accordion__content share-items">
                                                  {%- liquid
                                                  assign share_image = product.selected_or_first_available_variant.featured_media.preview_image | default: product.featured_media.preview_image
                                                  render 'share', share_settings: block.settings, share_title: product.title, share_link: product.url, share_variant_url: product.selected_variant.url, share_image: share_image
                                                  -%}
                                              </div>
                                              </div>
                                          </div>
                                          </accordion-block>
                                      {% else %}
                                          {%- liquid
                                          assign share_image = product.selected_or_first_available_variant.featured_media.preview_image | default: product.featured_media.preview_image
                                          render 'share', share_settings: block.settings, share_title: product.title, share_link: product.url, share_variant_url: product.selected_variant.url, share_image: share_image
                                          -%}
                                      {% endif %}
                                      </div>
                                  {%- when 'rating' -%}
                                      {%- if product.metafields.reviews.rating.value != blank -%}
                                        {% style %}
                                          .popup-wrapper__quick-view .rating-container {
                                              --layout-text-color:
                                                  {{ settings.layout_text_color.red }},
                                                  {{ settings.layout_text_color.green }}, 
                                                  {{ settings.layout_text_color.blue }};
                                              --layout-background-color:
                                                  {{ settings.layout_background_color.red }},
                                                  {{ settings.layout_background_color.green }},
                                                  {{ settings.layout_background_color.blue }};
                                              --rating-color: 
                                                  {{ settings.rating_color.red }},
                                                  {{ settings.rating_color.green }},
                                                  {{ settings.rating_color.blue }} !important;
                                          }
                                        {% endstyle %}
                                      <a class="rating-container rating-container--main-product rating-container--{{ settings.typography_preset }}" href="#" onclick="var el=document.querySelector('[id*=\'reviews\'][data-id=\'{{ product.id }}\']');el&&el.scrollIntoView();return false;">
                                          {% liquid
                                          assign rating_decimal = 0
                                          assign decimal = product.metafields.reviews.rating.value.rating | modulo: 1
                                          assign rating_decimal = decimal
                                          %}
                                          <div class="rating" role="img" aria-label="{{ 'accessibility.star_reviews_info' | t: rating_value: product.metafields.reviews.rating.value, rating_max: product.metafields.reviews.rating.value.scale_max }}">
                                          <span aria-hidden="true" class="rating-star rating-star--{{ settings.typography_preset }}" style="--rating: {{ product.metafields.reviews.rating.value.rating | floor }}; --rating-max: {{ product.metafields.reviews.rating.value.scale_max }}; --rating-decimal: {{ rating_decimal }};"></span>
                                          </div>
                                          <p class="rating-text caption">
                                          <span aria-hidden="true">{{ product.metafields.reviews.rating.value | slice: 0, 3 }} / {{ product.metafields.reviews.rating.value.scale_max }}</span>
                                          </p>
                                          <p class="rating-count caption">
                                          <span aria-hidden="true">{{ product.metafields.reviews.rating_count }} {% if product.metafields.reviews.rating_count > 1 %}{{ "accessibility.reviews" | t }}{% else %}{{ "accessibility.review" | t }}{% endif %}</span>
                                          <span class="visually-hidden">{{ product.metafields.reviews.rating_count }} {{ "accessibility.total_reviews" | t }}</span>
                                          </p>
                                      </a>
                                      {%- endif -%}
                                  {%- when 'related_collections' -%}
                                      {% if block.settings.heading != blank or block.settings.collection_by_brand or block.settings.shop_by_brand or block.settings.shop_the_collection %}
                                      {%- render 'product-related-collections', related_collections_settings: block.settings, block_item: block, section_content: false -%}
                                      {% endif %}
                                  {%- when 'price' -%}
                                    {% liquid
                                      assign hide_price = false
                                      if block.settings.show_price == false
                                        assign hide_price = true
                                      endif
                                    %}
                                      <div class="no-js-hidden price-block {% if hide_price and block.settings.hide_shipping_note %}price-block-hidden{% endif %}{% if hide_price %} price-block-hidden-price{% endif %}{% if hide_price and block.settings.hide_shipping_note and block.settings.show_badges == false %} price-block-hidden-no-badges{% endif %}" id="price-{{ section.id }}" role="status" {{ block.shopify_attributes }}>
                                      {%- render 'price', product: product, price_settings: block.settings, use_variant: true, show_badges: block.settings.show_badges, type: block.type, hide_price: hide_price -%}
                                      {%- unless block.settings.hide_shipping_note -%}
                                      {%- if shop.shipping_policy.body != blank or cart.taxes_included -%}               
                                        <div class="product__shipping-policy richtext {% if settings.enable_animated_underline %}richtext-link--underline{% endif %} product__shipping-policy--{{ settings.typography_preset }} {% if settings.dim_text %}dim{% endif %}">
                                          {% if cart.taxes_included %}{{ 'products.product.include_taxes' | t }}&nbsp;{% endif %}{% if shop.shipping_policy.body != blank %}{{ 'products.product.shipping_policy_html' | t: link: shop.shipping_policy.url }}{% endif %}
                                        </div>
                                      {%- endif -%}
                                      {%- endunless -%}
                                      <div class="product__payment-terms product__payment-terms--{{ settings.typography_preset }}">
                                          {%- form 'product', product, data-productid: product.id, id: 'product-form-installment', class: 'installment caption-large' -%}
                                          <input type="hidden" name="id" data-productid="{{ product.id }}" value="{{ product.selected_or_first_available_variant.id }}">
                                          {{ form | payment_terms }}
                                          {%- endform -%}
                                      </div>
                                      </div>
                                  {%- when 'pickup_availability' -%}
                                    {% liquid
                                      assign current_store = nil
                                      assign availability = nil
                
                                      if cart.attributes['store'] != blank
                                        assign current_store = cart.attributes['store']
                                        assign pick_up_availabilities = product.selected_or_first_available_variant.store_availabilities 
                
                                        assign current_store_availability = nil
                                        for availability in pick_up_availabilities 
                                          if availability.location.name == current_store 
                                            assign current_store_availability = availability 
                                            break
                                          endif 
                                        endfor
                
                                        if current_store_availability.available and current_store_availability.pick_up_enabled
                                          assign availability = 'available'
                                        else
                                          assign availability = 'unavailable'
                                        endif
                                      endif   
                                    %}
                
                                    {% unless block.settings.hide_store_selection_text and current_store == nil %}
                                      {% render 'pickup-availability', block: block, availability: availability %}
                                    {% endunless %}
                                  {%- when 'quantity_selector' -%}
                                      <div class="product-form__input product-form__quantity" {{ block.shopify_attributes }}>
                                      {% if block.settings.show_label %}
                                          <label class="form__label label--{{ settings.typography_preset }} {% if settings.dim_text %}dim{% endif %}" for="Quantity-{{ section.id }}">
                                          {{ 'products.product.quantity.label' | t }}
                                          </label>
                                      {% endif %}
                                      {% assign weight = settings.base_icon_weight %}
                                      <quantity-input class="quantity">
                                          <button class="quantity__button no-js-hidden" name="minus" type="button">
                                          <span class="visually-hidden">{{ 'products.product.quantity.decrease' | t: product: product.title | escape }}</span>
                                              {% if weight == 'regular' %}
                                                      {% render 'icon', icon: 'minus-regular' %}
                                              {% elsif weight == 'medium' %}
                                                      {% render 'icon', icon: 'minus-medium' %}
                                              {% elsif weight == 'bold' %}
                                                      {% render 'icon', icon: 'minus-bold' %}
                                              {% endif %}
                                          </button>
                                          <input class="quantity__input label--{{ settings.typography_preset }}{% if settings.typography_preset == 'custom' %}{% if settings.uppercase_body_s %} uppercase{% endif %}{% if settings.bolder_font_body_s %} bolder-font{% endif %}{% endif %}"
                                              type="number"
                                              dir="ltr"
                                              name="quantity"
                                              id="Quantity-{{ section.id }}"
                                              aria-label="{{ 'products.product.quantity.input_label' | t: product: product.title | escape }}"
                                              min="1"
                                              value="1"
                                              form="{{ product_form_id }}"
                                              onclick="this.select();"
                                          >
                                          <button class="quantity__button no-js-hidden" name="plus" type="button">
                                          <span class="visually-hidden">{{ 'products.product.quantity.increase' | t: product: product.title | escape }}</span>
                                              {% if weight == 'regular' %}
                                                      {% render 'icon', icon: 'plus-regular' %}
                                              {% elsif weight == 'medium' %}
                                                      {% render 'icon', icon: 'plus-medium' %}
                                              {% elsif weight == 'bold' %}
                                                      {% render 'icon', icon: 'plus-bold' %}
                                              {% endif %}
                                          </button>
                                      </quantity-input>
                                      </div>
                                  {%- when 'variant_picker' -%}
                                    {% render 'product-variant-picker', product: product, block: block, product_form_id: product_form_id, weight_accordion_title: weight_accordion_title %}
                                  {%- when 'buy_buttons' -%}
                                    {% if settings.disable_shopping_functionality == false %}
                                      {% if block.settings.price_in_button and block.settings.display_in_a_row == false %}
                                        <div class="no-js-hidden price-block" id="price-{{ section.id }}" role="status" style="position: absolute !important;overflow: clip;width: 1px;height: 1px;margin: -1px;padding: 0;clip: rect(0 0 0 0);word-wrap: normal !important;">
                                          {%- render 'price', product: product, price_settings: block.settings, use_variant: true, show_badges: true, type: block.type -%}
                                        </div>
                                      {% endif %}
                                      {%- render 'buy-buttons', block: block, product: product, product_form_id: product_form_id, section_id: section.id, show_pickup_availability: true -%}
                                    {% endif %}
                                  {%- when 'image' -%}
                                    {% if block.settings.image != blank or request.design_mode %}
                                    {% if block.settings.image_link != blank %}<a class="image-block" href="{{ block.settings.image_link }}" {% if block.settings.image_target_blank %}target="_blank"{% endif %}>{% else %}<div class="image-block">{% endif %}
                                    {%- render 'image', image_settings: block.settings, type: block.type, block_item: block, image_width: block.settings.image_width. id: block.id -%}
                                    {% if block.settings.image_link != blank %}</a>{% else %}</div>{% endif %}
                                    {% endif %}
                                  {%- when 'line' -%}
                                    <div class="line-container line-container--{{ section.id }} line-container--{{ block.id }}" id="{{ block.id }}" data-block-index="{{ forloop.index0 }}" {{ block.shopify_attributes }}>
                                        {% style %}
                                        .line-container--{{ block.id }} {
                                            --padding-top: {{ block.settings.desktop_padding_top }}px;
                                            --padding-bottom: {{ block.settings.desktop_padding_bottom }}px;
                                        }
                                        @media screen and (max-width: 920px) {
                                            .line-container--{{ block.id }} {
                                            --padding-top: {{ block.settings.mobile_padding_top }}px;
                                            --padding-bottom: {{ block.settings.mobile_padding_bottom }}px;
                                            }
                                        }
                                        {% endstyle %}  
                                        <span class="line"></span>
                                    </div>
                                  {%- when 'empty_space' -%}
                                      <div class="empty-space" style="--desktop-height: {{ block.settings.desktop_height }}px; --mobile-height: {{ block.settings.mobile_height }}px;" data-block-index="{{ forloop.index0 }}"></div>
                                  {% when 'stock_indicator' %}
                                    {% if block.settings.low_threshold != blank and block.settings.base_quantity != blank %}
                                        <ul class="product__inventory list-unstyled" id="inventory-{{ section.id }}" {{ block.shopify_attributes }}>
                                        {%- liquid
                                            assign inventory_visible = false
                                            assign base_quantity = block.settings.base_quantity | plus: 0
                                            assign inventory_threshold = block.settings.low_threshold | plus: 0
                                            assign inventory_quantity = product.selected_or_first_available_variant.inventory_quantity

                                            if product.selected_or_first_available_variant.inventory_management == 'shopify'
                                            if inventory_quantity <= block.settings.low_threshold and inventory_quantity >= 0
                                                assign inventory_visible = true
                                            endif
                                            endif

                                            assign show_incoming = false
                                            if product.selected_or_first_available_variant.incoming and inventory_visible == false and inventory_quantity <= inventory_threshold
                                            assign show_incoming = true
                                            endif
                                        -%}
                                        
                                            {%- if inventory_quantity > inventory_threshold or product.selected_or_first_available_variant.inventory_policy == 'continue' and inventory_quantity <= 0 or product.selected_or_first_available_variant.available -%}
                                            {% unless product.selected_or_first_available_variant.incoming and block.settings.show_transfer %}
                                                <li class="product__inventory-item product__inventory-item--in-stock" style="--in-stock-color: {{ block.settings.in_stock_color.red }}, {{ block.settings.in_stock_color.green }}, {{ block.settings.in_stock_color.blue }};">
                                                {% if block.settings.show_label %}
                                                    <p class="product__inventory-label label--{{ settings.typography_preset }} {% if block.settings.label_size != 'default' %}{{ block.settings.label_size }}{% else %}{% if settings.typography_preset == 'custom' %}{% if settings.uppercase_body_s %} uppercase{% endif %}{% if settings.bolder_font_body_s %} bolder-font{% endif %}{% endif %}{% endif %} {% if settings.dim_text %}dim{% endif %}">{{ 'products.product.inventory.inventory_label' | t }}</p>
                                                {% endif %}
                                                <p class="product__inventory-status input--{{ settings.typography_preset }} {% if block.settings.text_size != 'default' %}{{ block.settings.text_size }}{% else %}{% if settings.typography_preset == 'custom' %}{% if settings.uppercase_body_s %} uppercase{% endif %}{% if settings.bolder_font_body_s %} bolder-font{% endif %}{% endif %}{% endif %}">{{ 'products.product.inventory.in_stock_label' | t: count: product.selected_or_first_available_variant.inventory_quantity }}</p>
                                                {% if block.settings.show_bar %}
                                                    <progress-bar class="progress-bar"></progress-bar>
                                                {% endif %}
                                                </li>
                                            {% endunless %}
                                            
                                            {%- elsif inventory_threshold >= inventory_quantity and inventory_quantity >= 0 and product.selected_or_first_available_variant.inventory_management == 'shopify' -%}
                                            <li class="product__inventory-item product__inventory-item--low" style="--low-inventory-color: {{ block.settings.low_inventory_color.red }}, {{ block.settings.low_inventory_color.green }}, {{ block.settings.low_inventory_color.blue }};">
                                                {% if block.settings.show_label %}
                                                <p class="product__inventory-label label--{{ settings.typography_preset }} {% if block.settings.label_size != 'default' %}{{ block.settings.label_size }}{% else %}{% if settings.typography_preset == 'custom' %}{% if settings.uppercase_body_s %} uppercase{% endif %}{% if settings.bolder_font_body_s %} bolder-font{% endif %}{% endif %}{% endif %} {% if settings.dim_text %}dim{% endif %}">{{ 'products.product.inventory.inventory_label' | t }}</p>
                                                {% endif %}
                                                <p class="product__inventory-status input--{{ settings.typography_preset }} {% if block.settings.text_size != 'default' %}{{ block.settings.text_size }}{% else %}{% if settings.typography_preset == 'custom' %}{% if settings.uppercase_body_s %} uppercase{% endif %}{% if settings.bolder_font_body_s %} bolder-font{% endif %}{% endif %}{% endif %}">{{ 'products.product.inventory.stock_label_html' | t: count: product.selected_or_first_available_variant.inventory_quantity }}</p>
                                                {% if block.settings.show_bar %}
                                                <progress-bar class="{{ block.settings.color_scheme }}" data-quantity="{{ product.selected_or_first_available_variant.inventory_quantity }}" data-total="{{ block.settings.base_quantity }}"></progress-bar>
                                                {% endif %}
                                            </li>
                                            {%- elsif inventory_quantity <= 0 and product.selected_or_first_available_variant.inventory_policy == 'deny' -%}
                                            {% unless product.selected_or_first_available_variant.incoming and block.settings.show_transfer %}
                                                <li class="product__inventory-item product__inventory-item--sold" style="--out-of-stock-color: {{ block.settings.sold_out_color.red }}, {{ block.settings.sold_out_color.green }}, {{ block.settings.sold_out_color.blue }};">
                                                {% if block.settings.show_label %}
                                                    <p class="product__inventory-label label--{{ settings.typography_preset }} {% if block.settings.label_size != 'default' %}{{ block.settings.label_size }}{% else %}{% if settings.typography_preset == 'custom' %}{% if settings.uppercase_body_s %} uppercase{% endif %}{% if settings.bolder_font_body_s %} bolder-font{% endif %}{% endif %}{% endif %} {% if settings.dim_text %}dim{% endif %}">{{ 'products.product.inventory.inventory_label' | t }}</p>
                                                {% endif %}
                                                <p class="product__inventory-status input--{{ settings.typography_preset }} {% if block.settings.text_size != 'default' %}{{ block.settings.text_size }}{% else %}{% if settings.typography_preset == 'custom' %}{% if settings.uppercase_body_s %} uppercase{% endif %}{% if settings.bolder_font_body_s %} bolder-font{% endif %}{% endif %}{% endif %}">{{ 'products.product.inventory.out_of_stock' | t: count: product.selected_or_first_available_variant.inventory_quantity }}</p>
                                                {% if block.settings.show_bar %}
                                                    <progress-bar class="progress-bar"></progress-bar>
                                                {% endif %}
                                                </li>                        
                                            {% endunless %}
                                            {%- endif -%}
                                        
                                        {%- if block.settings.show_transfer and product.selected_or_first_available_variant.incoming -%}
                                            {% if inventory_quantity <= 0 %}
                                            <li class="product__inventory-item">
                                                {% if block.settings.show_label %}
                                                <p class="product__inventory-label label--{{ settings.typography_preset }} {% if block.settings.label_size != 'default' %}{{ block.settings.label_size }}{% else %}{% if settings.typography_preset == 'custom' %}{% if settings.uppercase_body_s %} uppercase{% endif %}{% if settings.bolder_font_body_s %} bolder-font{% endif %}{% endif %}{% endif %} {% if settings.dim_text %}dim{% endif %}">{{ 'products.product.inventory.inventory_label' | t }}</p>
                                                {% endif %}
                                                <span class="icon-and-text">
                                                <span class="icon icon--inventory"></span>
                                                <span class="js-incoming-text input--{{ settings.typography_preset }} {% if block.settings.text_size != 'default' %}{{ block.settings.text_size }}{% else %}{% if settings.typography_preset == 'custom' %}{% if settings.uppercase_body_s %} uppercase{% endif %}{% if settings.bolder_font_body_s %} bolder-font{% endif %}{% endif %}{% endif %}" style="--in-stock-color: {{ block.settings.in_stock_color.red }}, {{ block.settings.in_stock_color.green }}, {{ block.settings.in_stock_color.blue }};">
                                                    {%- liquid
                                                    if product.selected_or_first_available_variant.next_incoming_date
                                                        assign date = product.selected_or_first_available_variant.next_incoming_date | date: format: 'date'
                                                        if product.selected_or_first_available_variant.inventory_quantity <= 0
                                                        echo 'products.product.inventory.will_not_ship_until' | t: date: date
                                                        else
                                                        echo 'products.product.inventory.will_be_in_stock_after' | t: date: date
                                                        endif
                                                    else
                                                        echo 'products.product.inventory.waiting_for_stock' | t
                                                    endif
                                                    -%}
                                                </span>
                                                </span>
                                            </li>
                                            {% endif %}
                                        {%- endif -%}
                                        </ul>
                                    {% endif %}
                                  {% when 'more_details' %}
                                    {% if block.settings.button_label != blank %}
                                        <div class="more-details">
                                          <a class="more-details__link icon-button link-button button--{{ settings.typography_preset }} {% if block.settings.link_size != 'default' %}{{ block.settings.link_size }}{% else %}{% if settings.typography_preset == 'custom' %}{% if settings.uppercase_body_s %} uppercase{% endif %}{% if settings.bolder_font_body_s %} bolder-font{% endif %}{% endif %}{% endif %} {% if settings.enable_animated_underline %}link-button--underline{% endif %}" href="{{ product.url }}">
                                              <span class="icon-button__title">{{ block.settings.button_label }}</span>
                                              <span class="more-details__link-icon share--icon">
                                                  {% if weight == 'regular' %}
                                                    {% render 'icon-accordion', icon: 'arrow-right-regular' %}
                                                  {% elsif weight == 'medium' %}
                                                      {% render 'icon-accordion', icon: 'arrow-right-medium' %}
