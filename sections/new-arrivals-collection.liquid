{% if request.design_mode or section.settings.collection %}
    {{ 'section-media-with-text.css' | asset_url | stylesheet_tag }}
    {{ 'component-price.css' | asset_url | stylesheet_tag }}
    {{ 'section-slider.css' | asset_url | stylesheet_tag }}
    {{ 'component-product-card.css' | asset_url | stylesheet_tag }}
    {{ 'component-slider.css' | asset_url | stylesheet_tag }}
    {{ 'section-featured-collection.css' | asset_url | stylesheet_tag }}
    
    {% style %}
      #shopify-section-{{ section.id }} {
        --padding-top: {{ section.settings.desktop_padding_top }}px;
        --padding-bottom: {{ section.settings.desktop_padding_bottom }}px;
        --media-focal-point: {{ section.settings.focal_point }};
        --focal-point: {{ section.settings.card_focal_point }};
        --image-position: {% if section.settings.swap_image %}row{% else %}row-reverse{% endif %};
        --vertical-position: {{ section.settings.vertical_text_alignment }};
        --horizontal-position: {{ section.settings.horizontal_text_alignment }};
        --page-width: {{ settings.max_page_width }}px;
    
        {% if section.settings.image_radius == 'default' %}
            --image-radius: {{ settings.images_and_sections_radius }};
        {% else %}
            --image-radius: {{ section.settings.image_radius }};
        {% endif %}
    
        {% if section.settings.color_type == 'invert' %}
            --layout-text-color:
            {{ settings.layout_background_color.red }},
            {{ settings.layout_background_color.green }},
            {{ settings.layout_background_color.blue }};
            --layout-background-color:
            {{ settings.layout_text_color.red }},
            {{ settings.layout_text_color.green }}, 
            {{ settings.layout_text_color.blue }};
            --rating-color: 
            {{ settings.layout_background_color.red }},
            {{ settings.layout_background_color.green }},
            {{ settings.layout_background_color.blue }};
        {% endif %}
        {% if section.settings.color_type == 'custom' %}
            --layout-text-color:
            {{ section.settings.text_color.red }},
            {{ section.settings.text_color.green }}, 
            {{ section.settings.text_color.blue }};
            --layout-background-color:
            {{ section.settings.background_color.red }},
            {{ section.settings.background_color.green }}, 
            {{ section.settings.background_color.blue }};
            --rating-color: 
            {{ section.settings.text_color.red }},
            {{ section.settings.text_color.green }}, 
            {{ section.settings.text_color.blue }};
        {% endif %}  
        background-color: rgb(var(--layout-background-color));
        color: rgb(var(--layout-text-color));
      }
      @media screen and (max-width: 920px) {
        #shopify-section-{{ section.id }} {
          --padding-top: {{ section.settings.mobile_padding_top }}px;
          --padding-bottom: {{ section.settings.mobile_padding_bottom }}px;
        }
      }
    {% endstyle %}
    
    {% liquid
      assign settings_page_width = settings.max_page_width | append: 'px'
      if settings.max_page_width == 'full_width'
        assign settings_page_width = '100vw'
      endif
      assign grid_items_desktop = section.settings.desktop_grid_type | times: 1
      assign mobile_layout = section.settings.mobile_layout | times: 1
      if section.settings.collection.products.size == 1
        assign mobile_layout = 1
      endif
      if section.settings.collection.all_products_count < mobile_layout
        assign mobile_layout = section.settings.collection.all_products_count
      endif
      assign limit_products = section.settings.product_range
      assign sort_collection = section.settings.collection.products | sort: 'created_at' | reverse
    %}
    
    <div class="featured-collection-with-media featured-collection-with-media--{{ section.id }} ordinal-section ordinal-section--{{ settings.white_space }} {% if settings.show_lines %}ordinal-section--lines lines{% endif %} media-with-text media-with-text--{{ settings.white_space }} section-padding--{{ settings.white_space }} {% if settings.max_page_width == '1400' or settings.max_page_width == '1200' %}page-width {% endif %} page-width--{{ settings.max_page_width }} {% if section.settings.swap_image %}image-left{% else %}image-right{% endif %} color-{{ section.settings.color_type }} {% if section.settings.color_type != 'default' %}no-default-color{% endif %} include-lines">
        <div class="media-with-text__wrapper section-featured-collection section-featured-collection--{{ settings.white_space }}">
            <div class="media-with-text__card {{ section.settings.image_size }}">
                {%- unless section.settings.media_style == 'hide' -%}
                <div class="media-with-text__media {% if section.settings.swap_image %}right-padding--media{% else %}left-padding--media{% endif %}{% if section.settings.media_style == 'show_on_desktop' %} show-on-desktop{% endif %}">
                    <div class="media-with-text__media-wrapper lazy-image-container ratio-{{ section.settings.image_ratio }} section-featured-collection__media" {% if settings.disable_right_click %}oncontextmenu="return false"{% endif %}>
                        {% comment %}theme-check-disable ImgLazyLoading{% endcomment %}
                        {%- if section.settings.video_load != blank -%}
                          {% if settings.images_loading == 'disable' %}
                            {{ section.settings.video_load | video_tag: image_size: "500x", autoplay: false, preload: 'none', loop: true, muted: true, controls: false, alt: section.settings.video_load.alt }}
                          {% else %}
                            <figure class="lazy-video lazy-image--{{ settings.images_loading }}" style="--desktop-asp-rat: {{ section.settings.video_load.aspect_ratio }}">
                                {{ section.settings.video_load | video_tag: image_size: "500x", autoplay: false, preload: 'none', loop: true, muted: true, controls: false, alt: section.settings.video_load.alt, oncanplay: 'this.parentNode.classList.add("lazyloaded");' }}
                                {% if settings.images_loading != 'fade_scale' %}
                                <div class="lazy-image__preloader lazy-image__preloader--full lazy-image__preloader-{{ settings.images_loading }}" aria-hidden="true" >
                                    <img 
                                      alt="{{ section.settings.video_load.alt | escape }}" 
                                      src="{{ section.settings.video_load.preview_image | image_url: width: 10 }}"
                                      draggable="false"
                                      width="10" 
                                      height="10">
                                </div>
                                {% endif %}
                            </figure>
                          {% endif %}
                        {%- elsif section.settings.custom_image != blank -%}
                          {% if settings.images_loading != 'disable' %}
                            <figure class="lazy-image lazy-image--{{ settings.images_loading }}" style="--desktop-asp-rat: {{ section.settings.custom_image.aspect_ratio }}">
                          {% endif %}
                            <img srcset="{%- if section.settings.custom_image.width >= 165 -%}{{ section.settings.custom_image | image_url: width: 165 }} 165w,{%- endif -%}
                                {%- if section.settings.custom_image.width >= 375 -%}{{ section.settings.custom_image | image_url: width: 375 }} 375w,{%- endif -%}
                                {%- if section.settings.custom_image.width >= 550 -%}{{ section.settings.custom_image | image_url: width: 550 }} 550w,{%- endif -%}
                                {%- if section.settings.custom_image.width >= 750 -%}{{ section.settings.custom_image | image_url: width: 750 }} 750w,{%- endif -%}
                                {%- if section.settings.custom_image.width >= 1100 -%}{{ section.settings.custom_image | image_url: width: 1100 }} 1100w,{%- endif -%}
                                {%- if section.settings.custom_image.width >= 1500 -%}{{ section.settings.custom_image | image_url: width: 1500 }} 1500w,{%- endif -%}
                                {{ section.settings.custom_image | image_url }} {{ section.settings.custom_image.width }}w" src="{{ section.settings.custom_image | image_url: width: 1700 }}"
                                {% if section.settings.image_size == 'large' %}
                                  sizes="(max-width: 768) 100vw, (min-width: {{ settings_page_width }}) calc({{ settings_page_width }} / 3 * 2), calc(100vw / 3 * 2)"
                                {% elsif section.settings.image_size == 'half' %}
                                  sizes="(max-width: 768) 100vw,(min-width: {{ settings_page_width }}) calc({{ settings_page_width }} / 2), calc(100vw / 2)"
                                {% else %}
                                  sizes="(max-width: 768) 100vw, (min-width: {{ settings_page_width }}) calc({{ settings_page_width }} / 3), calc(100vw / 3)"
                                {% endif %}
                                alt="{{ section.settings.custom_image.alt | escape }}" 
                                src="{{ section.settings.custom_image | image_url: width: 1500 }}"
                                {% if settings.images_loading != 'disable' %}
                                  loading="lazy"
                                  onload="this.parentNode.classList.add('lazyloaded');"
                                {% else %}
                                    {% if section.index > 2 %}loading="lazy"{% endif %}
                                {% endif %}
                                draggable="false"
                                width="{{ section.settings.custom_image.width }}" 
                                height="{{ section.settings.custom_image.height }}" 
                                class="section-featured-collection__image"
                                style="--media-focal-point: {{ section.settings.custom_image.presentation.focal_point }};">
                            {% if settings.images_loading != 'disable' %}
                              {% if settings.images_loading != 'fade_scale' %}
                              <div class="lazy-image__preloader lazy-image__preloader--full lazy-image__preloader-{{ settings.images_loading }}" aria-hidden="true">
                                  <img 
                                  alt="{{ section.settings.custom_image.alt | escape }}" 
                                  src="{{ section.settings.custom_image | image_url: width: 10 }}"
                                  draggable="false"
                                  width="10" 
                                  height="10">
                              </div>
                              {% endif %}
                              </figure>
                          {% endif %}
                        {%- else -%}   
                            {%- if section.settings.collection.featured_image -%}
                              {% if settings.images_loading != 'disable' %}
                                <figure class="lazy-image lazy-image--{{ settings.images_loading }}" style="--desktop-asp-rat: {{ section.settings.collection.featured_image.aspect_ratio }}">
                              {% endif %}
                                <img srcset="{%- if section.settings.collection.featured_image.width >= 165 -%}{{ section.settings.collection.featured_image | image_url: width: 165 }} 165w,{%- endif -%}
                                    {%- if section.settings.collection.featured_image.width >= 375 -%}{{ section.settings.collection.featured_image | image_url: width: 375 }} 375w,{%- endif -%}
                                    {%- if section.settings.collection.featured_image.width >= 550 -%}{{ section.settings.collection.featured_image | image_url: width: 550 }} 550w,{%- endif -%}
                                    {%- if section.settings.collection.featured_image.width >= 750 -%}{{ section.settings.collection.featured_image | image_url: width: 750 }} 750w,{%- endif -%}
                                    {%- if section.settings.collection.featured_image.width >= 1100 -%}{{ section.settings.collection.featured_image | image_url: width: 1100 }} 1100w,{%- endif -%}
                                    {%- if section.settings.collection.featured_image.width >= 1500 -%}{{ section.settings.collection.featured_image | image_url: width: 1500 }} 1500w,{%- endif -%}
                                    {{ section.settings.collection.featured_image | image_url }} {{ section.settings.collection.featured_image.width }}w" src="{{ section.settings.collection.featured_image | image_url: width: 1700 }}"
                                    {% if section.settings.image_size == 'large' %}
                                      sizes="(max-width: 768) 100vw, (min-width: {{ settings_page_width }}) calc({{ settings_page_width }} / 3 * 2), calc(100vw / 3 * 2)"
                                    {% elsif section.settings.image_size == 'half' %}
                                      sizes="(max-width: 768) 100vw,(min-width: {{ settings_page_width }}) calc({{ settings_page_width }} / 2), calc(100vw / 2)"
                                    {% else %}
                                      sizes="(max-width: 768) 100vw, (min-width: {{ settings_page_width }}) calc({{ settings_page_width }} / 3), calc(100vw / 3)"
                                    {% endif %}
                                    alt="{{ section.settings.collection.title | escape }}" 
                                    src="{{ section.settings.collection | image_url: width: 1500 }}"
                                    {% if settings.images_loading != 'disable' %}
                                      loading="lazy"
                                      onload="this.parentNode.classList.add('lazyloaded');"
                                    {% else %}
                                        {% if section.index > 2 %}loading="lazy"{% endif %}
                                    {% endif %}
                                    draggable="false"
                                    width="{{ section.settings.collection.featured_image.width }}" 
                                    height="{{ section.settings.collection.featured_image.height }}" 
                                    class="section-featured-collection__image">
                                {% if settings.images_loading != 'disable' %}
                                  {% if settings.images_loading != 'fade_scale' %}
                                  <div class="lazy-image__preloader lazy-image__preloader--full lazy-image__preloader-{{ settings.images_loading }}" aria-hidden="true">
                                      <img 
                                      alt="{{ section.settings.collection.featured_image.alt | escape }}" 
                                      src="{{ section.settings.collection.featured_image | image_url: width: 10 }}"
                                      draggable="false"
                                      width="10" 
                                      height="10">
                                  </div>
                                  {% endif %}
                                  </figure>
                              {% endif %}
                            {%- else -%}
                                {{ 'collection-5' | placeholder_svg_tag: 'placeholder-svg' }}
                            {%- endif -%}
                        {%- endif -%} 
                        {% comment %}theme-check-enable ImgLazyLoading{% endcomment %}
                    </div>
                </div>
                {%- endunless -%}
                {%- if section.settings.subheading != blank or section.settings.heading != blank or section.settings.text != blank or section.settings.button_label != blank -%}
                <div class="media-with-text__content {% if section.settings.swap_image %}left-padding{% else %}right-padding{% endif %}">
                  {%- liquid
                    assign aligment = 'none'               
                      if section.settings.narrow_content and section.settings.image_size != "large" and section.settings.desktop_width != 'narrow'
                          if section.settings.horizontal_text_alignment == 'flex-start'
                            assign aligment = 'right'
                          elsif section.settings.horizontal_text_alignment == 'center'
                            assign aligment = 'center'
                          else
                            assign aligment = 'left'
                          endif
                      endif
                  -%}  
                    <div class="media-with-text__content-wrapper {% if settings.enable_buttons_zoom %}buttons-zoom{% endif %} content-aligment-{{ aligment }} {% if section.settings.horizontal_text_alignment == 'flex-start' %}start{% elsif section.settings.horizontal_text_alignment == 'flex-end' %}end{% else %}center{% endif %}" style="text-align: {% if section.settings.horizontal_text_alignment == 'flex-start' %}start{% elsif section.settings.horizontal_text_alignment == 'flex-end' %}end{% else %}center{% endif %};">
                        {% if section.settings.subheading != blank %}
                            <{{ section.settings.subheading_tag }} class="content-subheading content-subheading--{{ settings.typography_preset }} {% if section.settings.subheading_size != 'default' %}{{ section.settings.subheading_size }}{% else %}{% if settings.typography_preset == 'custom' %}{% if settings.uppercase_label %} uppercase{% endif %}{% if settings.bolder_font_label %} bolder-font{% endif %}{% endif %}{% endif %} {% if settings.dim_text %}dim{% endif %}">{{ section.settings.subheading }}</{{ section.settings.subheading_tag }}>
                        {% endif %}
                        {% if section.settings.heading != blank %}
                            <{{ section.settings.heading_tag }} class="content-heading {% if section.settings.color_type == 'default' and settings.accent_color_for_headings %}content-heading--accent{% endif %} content-heading--{{ settings.typography_preset }} {% if section.settings.heading_size != 'default' %}{{ section.settings.heading_size }}{% else %}{% if settings.typography_preset == 'custom' %}{% if settings.uppercase_heading_xs %} uppercase{% endif %}{% if settings.bolder_font_heading_xs %} bolder-font{% endif %}{% endif %}{% endif %}">{{ section.settings.heading }}</{{ section.settings.heading_tag }}>
                        {% endif %}
                        {% if section.settings.text != blank %}
                            <div class="content-text content-text--{{ settings.typography_preset }} richtext {% if settings.enable_animated_underline %}richtext-link--underline{% endif %} {% if section.settings.main_text_size != 'default' %}{{ section.settings.main_text_size }}{% else %}{% if settings.typography_preset == 'custom' %}{% if settings.uppercase_body_m %} uppercase{% endif %}{% if settings.bolder_font_body_m %} bolder-font{% endif %}{% endif %}{% endif %}">
                                {{ section.settings.text }}
                              </div>
                        {% endif %}
                        {% if section.settings.button_label != blank %}
                          <div class="media-with-text__button {% if settings.enable_buttons_zoom %}buttons-zoom{% endif %}">
                            {% if section.settings.collection.url != blank %}<a href="{{ section.settings.collection.url }}" class="{{ section.settings.button_style }}-button button--{{ settings.typography_preset }} {% if settings.typography_preset == 'custom' %}{% if settings.regular_button_size == 'default' %}button-font--default{% else %}{{ settings.regular_button_size }}{% endif %}{% endif %} {% if section.settings.button_style == 'link' and settings.enable_animated_underline %}link-button--underline{% endif %} featured-collection-with-media__button">{% else %}
                            <span disabled class="{{ section.settings.button_style }}-button button--{{ settings.typography_preset }} {% if settings.typography_preset == 'custom' %}{% if settings.regular_button_size == 'default' %}button-font--default{% else %}{{ settings.regular_button_size }}{% endif %}{% endif %} {% if section.settings.button_style == 'link' and settings.enable_animated_underline %}link-button--underline{% endif %} featured-collection-with-media__button">{% endif %}  
                            {{ section.settings.button_label }}
                            {% if section.settings.collection.url == blank %}</span>{% else %}</a>{% endif %}
                          </div>
                          {% endif %}
                    </div>
                </div>
              {%- endif -%}
            </div>
                <div class="section-featured-collection__products slider-section--{{ settings.white_space }} {% if settings.show_lines %}slider-section--lines{% endif %} slider-container-js">
                    <slider-component id="GalleryViewer-{{ section.id }}" class="slider">
                        {% style %}
                            .featured-collection-with-media--{{ section.id }} {
                                --desktop-grid-type: {{ section.settings.desktop_grid_type }};
                            }
                            /* Styles for full-width page without sidebars */
                            /* Mobile */
                            @media screen and (max-width: 768px) {
                                .featured-collection-with-media--{{ section.id }} {
                                  --desktop-grid-type: {{ mobile_layout }};
                                }
                            }
                            /* Sidebars: Main XS,S,M and white space Spacious */
                            /* Mobile */
                            @media screen and (max-width: 1048px) and (min-width: 921px) {
                                .main_xs--spacious .featured-collection-with-media--{{ section.id }},
                                .main_s--spacious .featured-collection-with-media--{{ section.id }},
                                .main_m--spacious .featured-collection-with-media--{{ section.id }} {
                                    --desktop-grid-type: {{ mobile_layout }};
                                }
                            }
                            /* Sidebars: Main XS, Main S and white space Compact */
                            /* Mobile */
                            @media screen and (max-width: 968px) and (min-width: 921px) {
                                .main_xs--compact .featured-collection-with-media--{{ section.id }},
                                .main_s--compact .featured-collection-with-media--{{ section.id }} {
                                    --desktop-grid-type: {{ mobile_layout }};
                                }
                            }
                            /* Sidebars: Main XS,S with secondary and white space Spacious */
                            /* Mobile */
                            @media screen and (max-width: 1144px) and (min-width: 921px) {
                                .main_xs_with_secondary--spacious .featured-collection-with-media--{{ section.id }},
                                .main_s_with_secondary--spacious .featured-collection-with-media--{{ section.id }} {
                                    --desktop-grid-type: {{ mobile_layout }};
                                }
                            }
                            /* Sidebars: Main XS with secondary, Main S with secondary and white space Compact */
                            /* Mobile */
                            @media screen and (max-width: 1064px) and (min-width: 921px) {
                                .main_xs_with_secondary--compact .featured-collection-with-media--{{ section.id }},
                                .main_s_with_secondary--compact .featured-collection-with-media--{{ section.id }} {
                                    --desktop-grid-type: {{ mobile_layout }};
                                }
                            }
                            /* Sidebars: Main M and white space Compact */
                            /* Mobile */
                            @media screen and (max-width: 1024px) and (min-width: 921px) {
                                .main_m--compact  .featured-collection-with-media--{{ section.id }} {
                                    --desktop-grid-type: {{ mobile_layout }};
                                }
                            }
                            /* Sidebars: Main M with secondary*/
                            /* Mobile */
                            @media screen and (max-width: 1152px) and (min-width: 921px) {
                                .main_m_with_secondary  .featured-collection-with-media--{{ section.id }} {
                                    --desktop-grid-type: {{ mobile_layout }};
                                }
                            }
                            /* Sidebars: Main L */
                            /* Mobile */
                            @media screen and (max-width: 1536px) and (min-width: 921px) {
                                .main_l .featured-collection-with-media--{{ section.id }} {
                                    --desktop-grid-type: {{ mobile_layout }};
                                }
                            }
                        {% endstyle %}
                        <div class="slider__viewport">
                            <ul id="Slider-Gallery-{{ section.id }}" data-id="{{ section.id }}" class="slider__grid slider__grid--{{ settings.white_space }} slider__grid-mobile-{{ mobile_layout }} {% if settings.show_lines %} lines{% endif %}"
                                data-count="{{ section.settings.desktop_grid_type }}"
                                data-count-mobile="{{ mobile_layout }}">
                                {% assign desktopItems = section.settings.desktop_grid_type | times: 1 %}
                                {% assign mobileItems = mobile_layout %}
                              {%- if section.settings.collection != blank -%}
                                {% for item in sort_collection limit: limit_products %}
                                    {% assign lazy_load = false %}
                                    {%- if forloop.index > 2 -%}
                                    {%- assign lazy_load = true -%}
                                    {%- endif -%}
                                    <li id="Slide-{{ section.id }}" class="slider__grid-item  snap-align {% if forloop.first %}is-active{% endif %} {% if forloop.last and settings.show_lines and forloop.length >= desktopItems %}last-desktop{% endif %} 
                                    {% if forloop.last and settings.show_lines and forloop.length >= mobileItems %}last-mobile{% endif %}{% if limit_products == mobileItems %} last-element{% endif %}">
                                        {% render 'card-product',
                                        card_product: item,
                                        image_ratio: section.settings.card_image_ratio,
                                        show_vendor: section.settings.show_vendor,
                                        show_rating: section.settings.show_rating,
                                        hover_behavior: section.settings.hover_behavior,
                                        show_bullets: section.settings.show_bullets,
                                        lazy_load: lazy_load,
                                        enable_quick_view: section.settings.enable_quick_view,
                                        enable_add_to_cart: section.settings.enable_add_to_cart,
                                        price_position: section.settings.price_position,
                                        max_product_name_characters: section.settings.max_product_name_characters,
                                        show_short_description: section.settings.show_short_description,
                                        enable_color_pills: section.settings.enable_color_pills,
                                        show_pickup_availability: section.settings.show_pickup_availability
                                        %}
                                    </li>
                                {% endfor %}
                                {% else %}
                                {% for item in (1..limit_products) %}
                                    {% assign lazy_load = false %}
                                    {%- if forloop.index > 2 -%}
                                    {%- assign lazy_load = true -%}
                                    {%- endif -%}
                                    {%- assign placeholder_index =  forloop.index -%}
                                    {%- if forloop.index > 6 -%}
                                        {%- assign placeholder_index =  '6' -%}
                                    {%- endif -%}
                                    <li id="Slide-{{ section.id }}" class="slider__grid-item  snap-align {% if forloop.first %}is-active{% endif %} {% if forloop.last and settings.show_lines and forloop.length >= desktopItems %}last-desktop{% endif %}  
                                    {% if forloop.last and settings.show_lines and forloop.length >= mobileItems %}last-mobile{% endif %}{% if limit_products == mobileItems %} last-element{% endif %}">
                                        {% render 'product-placeholder',
                                        index_placeholder: placeholder_index,
                                        image_ratio: section.settings.card_image_ratio,
                                        show_vendor: section.settings.show_vendor,
                                        price_position: section.settings.price_position
                                        %}
                                    </li>
                                  {% endfor %}
                              {%- endif -%}
                            </ul>
                            {% assign mobileItems = mobile_layout %}
                            {% liquid
                              assign product_size = section.settings.collection.products.size
                              if section.settings.collection == blank
                                  assign product_size = limit_products
                              endif
                          %}
                            <div class="slider-buttons-items  slider-buttons-items--bottom slider-buttons-items--{{ settings.white_space }} {% if settings.show_lines %}slider-buttons-items--lines{% endif %} 
                                {% if limit_products <= grid_items_desktop or section.settings.collection.all_products_count <= grid_items_desktop %}hidden-desktop{% endif %}
                                {% if section.settings.desktop_grid_type == '5' %}hidden-desktop-none{% endif %}
                                {% if product_size <= mobileItems or section.settings.mobile_navigation == 'scrollbar' %}hidden-mobile{% endif %}">
                                    {%- liquid 
                                      if settings.typography_preset == 'avant_garde'
                                        assign weight_close = settings.accent_icon_weight
                                        if settings.swap_fonts
                                            assign weight_close = settings.base_icon_weight
                                        endif
                                      else 
                                        assign weight_close =  settings.base_icon_weight
                                        if settings.swap_fonts
                                            assign weight_close = settings.accent_icon_weight
                                        endif
                                      endif
                                      if settings.typography_preset == 'custom'
                                        assign weight_close = settings.custom_icon_weight
                                    endif
                                    -%}
                                <button type="button" class="slider-button slider-button--prev" name="previous" aria-label="{{ 'general.slider.previous_slide' | t }}">
                                  {% if weight_close == 'regular' %}
                                          {% render 'icon-accordion-2', icon: 'arrow-long-left-regular' %}
                                  {% elsif weight_close == 'medium' %}
                                          {% render 'icon-accordion-2', icon: 'arrow-long-left-medium' %}
                                  {% elsif weight_close == 'bold' %}
                                          {% render 'icon-accordion-2', icon: 'arrow-long-left-bold' %}
                                  {% endif %}
                                </button>
                                <button type="button" class="slider-button slider-button--next" name="next" aria-label="{{ 'general.slider.next_slide' | t }}">
                                  {% if weight_close == 'regular' %}
                                          {% render 'icon-accordion-2', icon: 'arrow-long-right-regular' %}
                                  {% elsif weight_close == 'medium' %}
                                          {% render 'icon-accordion-2', icon: 'arrow-long-right-medium' %}
                                  {% elsif weight_close == 'bold' %}
                                          {% render 'icon-accordion-2', icon: 'arrow-long-right-bold' %}
                                  {% endif %}
                                </button>
                            </div>
                            {% if section.settings.mobile_navigation == 'scrollbar' and product_size > mobileItems %}
                              <div role="scrollbar" aria-orientation="horizontal" aria-valuemax="100" aria-valuemin="0" aria-valuenow="39" class="slider-buttons-items slider-buttons-items--bottom slider-buttons-items--{{ settings.white_space }} slider-scrollbar hidden-desktop">
                                <span class="slider-scrollbar__track">
                                  <span class="slider-scrollbar__thumb"></span>
                                </span>
                              </div>
                            {% endif %}
                        </div>
                    </slider-component>
                </div>
          </div>
    </div>
    {% endif %}
    
